{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Hl7v2": {
    "MllpListenerPort": 2575,
    "DeadLetterPath": "./hl7-dlq",
    "AckCode": "AA"
  },
  "Fhir": {
    "ServerBaseUrl": "http://localhost:5050/fhir",
    "SupportedResources": [ "Patient", "Observation", "Encounter", "Condition", "MedicationRequest" ]
  },
  "Audit": {
    "Enabled": true,
    "Sink": "ApplicationInsights"
  }
}
